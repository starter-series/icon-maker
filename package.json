{
  "name": "iconkit",
  "version": "0.1.0",
  "description": "Compile one icon source into Xcode, app, extension, connector, and web delivery assets.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "iconkit": "bin/icon-maker.js",
    "icon-maker": "bin/icon-maker.js"
  },
  "files": [
    "src",
    "bin",
    "skills/create-icons",
    "examples",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src/ bin/ test/ scripts/",
    "test": "node --test",
    "pack:install-smoke": "node scripts/verify-packed-install.js",
    "xcode:smoke": "node scripts/verify-xcode-assets.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/starter-series/icon-maker.git"
  },
  "keywords": [
    "icons",
    "app-icon",
    "apple",
    "xcode",
    "asset-catalog",
    "browser-extension",
    "expo",
    "electron",
    "vscode",
    "pwa",
    "mcp",
    "starter-series"
  ],
  "author": "heznpc",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "globals": "^17.5.0",
    "license-checker-evergreen": "^6.3.1"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
